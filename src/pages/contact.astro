---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Love Your Words">
  <style>
    .contact-hero {
      padding: 100px 6% 60px;
      text-align: center;
      position: relative;
      overflow: hidden;
      background: #fff;
    }
    .contact-hero::before {
      content: '';
      position: absolute;
      top: -120px;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 700px;
      background: radial-gradient(ellipse at center,
        rgba(123,82,200,0.08) 0%,
        rgba(216,125,176,0.06) 40%,
        rgba(123,168,216,0.04) 70%,
        transparent 100%
      );
      pointer-events: none;
    }
    .hero-eyebrow {
      display: inline-block;
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #7B52C8;
      margin-bottom: 32px;
      position: relative;
    }
    .contact-hero h1 {
      max-width: 720px;
      margin: 0 auto 24px;
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -0.025em;
    }
    .hero-highlight {
      background: linear-gradient(135deg, #7B52C8 0%, #D87DB0 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .contact-hero p {
      max-width: 560px;
      margin: 0 auto;
      font-size: 1.125rem;
      line-height: 1.75;
      color: rgba(28,24,48,0.70);
      position: relative;
    }
    .contact-card-wrap {
      padding: 20px 6% 90px;
      background: #fff;
    }
    .contact-card {
      max-width: 560px;
      margin: 0 auto;
      background: #F7F4FE;
      border: 1px solid rgba(123,82,200,0.12);
      border-radius: 14px;
      padding: 48px 40px;
      text-align: center;
    }
    .contact-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #7B52C8;
      margin-bottom: 10px;
    }
    .contact-email {
      display: inline-block;
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: clamp(1.2rem, 3vw, 1.6rem);
      font-weight: 700;
      color: #1C1830;
      margin-bottom: 32px;
      word-break: break-all;
      text-decoration: none;
    }
    .contact-email:hover { color: #7B52C8; }
    .or-line {
      font-size: 0.9rem;
      color: rgba(28,24,48,0.55);
      margin-bottom: 32px;
    }
    .btn {
      display: inline-block;
      padding: 14px 40px;
      background: linear-gradient(135deg, #7B52C8, #D87DB0);
      color: #fff;
      border-radius: 40px;
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.2s, transform 0.2s;
    }
    .btn:hover { opacity: 0.9; transform: translateY(-2px); }
    .reply-note {
      margin-top: 28px;
      font-size: 0.9rem;
      color: rgba(28,24,48,0.6);
    }
    .closing-line {
      text-align: center;
      padding: 0 6% 80px;
      font-size: 1.05rem;
      color: #1C1830;
    }
  </style>

  <section class="contact-hero">
    <div class="hero-eyebrow">CONTACT</div>
    <h1>Tell me about the <span class="hero-highlight">people you serve.</span></h1>
    <p>A note about your organization is a fine place to start. A Discovery Call is even better: thirty minutes, one conversation about your content and where the gaps are.</p>
  </section>

  <section class="contact-card-wrap">
    <div class="contact-card">
      <div class="contact-label">Write Anytime</div>
      <a class="contact-email" href="mailto:hello@loveyourwords.com">hello@loveyourwords.com</a>
      <div class="or-line">or skip the typing and grab a time</div>
      <a class="btn" href="/discovery-call">Schedule a Discovery Call</a>
      <div class="reply-note">Every reply comes from a real person. Me.</div>
    </div>
  </section>

  <div class="closing-line">What's the story your people need to hear?</div>
</BaseLayout>
