---
import '../styles/global.css';
import siteData from '../content/site-data.json';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = '', ogImage } = Astro.props;
const siteTitle = `${title} | ${siteData.businessName}`;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon (generated during build) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- JSON-LD Schema (injected per page) -->
    <slot name="schema" />

    <!--
      CLAUDE: Replace this Google Fonts link during Milestone 1 Step 2.
      Write the full URL for the chosen heading and body fonts.
      Example: https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Lexend:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Additional head content -->
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-[--color-primary] focus:text-white focus:px-4 focus:py-2 focus:rounded">Skip to content</a>

    <header style="padding: 20px 6%; display: flex; align-items: center; justify-content: space-between; background: #fff; border-bottom: 1px solid rgba(123,82,200,0.12); position: sticky; top: 0; z-index: 50;">
      <a href="/" style="font-family: 'Outfit', system-ui, sans-serif; font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; background: linear-gradient(135deg, #7B52C8 0%, #D87DB0 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-decoration: none;">Love Your Words</a>
      <nav style="display: flex; gap: 36px;">
        <a href="/" style="font-size: 0.875rem; font-weight: 500; color: rgba(28,24,48,0.70); text-decoration: none; transition: color 0.2s;">Home</a>
        <a href="/about" style="font-size: 0.875rem; font-weight: 500; color: rgba(28,24,48,0.70); text-decoration: none; transition: color 0.2s;">About</a>
        <a href="/services" style="font-size: 0.875rem; font-weight: 500; color: rgba(28,24,48,0.70); text-decoration: none; transition: color 0.2s;">Services</a>
        <a href="/blog" style="font-size: 0.875rem; font-weight: 500; color: rgba(28,24,48,0.70); text-decoration: none; transition: color 0.2s;">Blog</a>
        <a href="/contact" style="font-size: 0.875rem; font-weight: 500; color: rgba(28,24,48,0.70); text-decoration: none; transition: color 0.2s;">Contact</a>
        <a href="/discovery-call" style="display: inline-block; padding: 11px 26px; background: linear-gradient(135deg, #7B52C8, #D87DB0); color: #fff; border-radius: 40px; font-family: 'Outfit', system-ui, sans-serif; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: opacity 0.2s, transform 0.2s;">Schedule a Call</a>
      </nav>
    </header>

    <slot />

    <footer style="background: #1C1830; color: rgba(255,255,255,0.85); padding: 56px 6% 32px;">
      <div style="max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 40px;">
        <div>
          <span style="font-family: 'Outfit', system-ui, sans-serif; font-size: 1.3rem; font-weight: 800; letter-spacing: -0.02em; background: linear-gradient(135deg, #B79AE8 0%, #E8A9CC 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; display: inline-block; margin-bottom: 12px;">Love Your Words</span>
          <p style="font-size: 0.95rem; line-height: 1.7; color: rgba(255,255,255,0.7); max-width: 280px;">Customer journey content for mission-driven organizations. Retention copy that keeps the people you already won.</p>
        </div>
        <div>
          <h3 style="font-family: 'Outfit', system-ui, sans-serif; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #B79AE8; margin-bottom: 16px;">Pages</h3>
          <a href="/" style="display: block; font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 10px; text-decoration: none;">Home</a>
          <a href="/about" style="display: block; font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 10px; text-decoration: none;">About</a>
          <a href="/services" style="display: block; font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 10px; text-decoration: none;">Services</a>
          <a href="/blog" style="display: block; font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 10px; text-decoration: none;">Blog</a>
          <a href="/contact" style="display: block; font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 10px; text-decoration: none;">Contact</a>
        </div>
        <div>
          <h3 style="font-family: 'Outfit', system-ui, sans-serif; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #B79AE8; margin-bottom: 16px;">Get In Touch</h3>
          <a href="mailto:hello@loveyourwords.com" style="display: block; font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 10px; text-decoration: none;">hello@loveyourwords.com</a>
          <a href="/discovery-call" style="display: block; font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 10px; text-decoration: none;">Schedule a Discovery Call</a>
        </div>
      </div>
      <div style="max-width: 1000px; margin: 40px auto 0; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.15); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">
        <span>© 2026 Love Your Words. Diane Anderson.</span>
        <span>
          <a href="/privacy-policy" style="color: rgba(255,255,255,0.7); margin-left: 20px; text-decoration: none;">Privacy Policy</a>
          <a href="/terms" style="color: rgba(255,255,255,0.7); margin-left: 20px; text-decoration: none;">Terms of Service</a>
        </span>
      </div>
    </footer>

    <!-- Analytics: inject tracking scripts per page or globally -->
    <slot name="analytics" />
  </body>
</html>
